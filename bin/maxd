#!/usr/bin/perl

use strict;
use warnings;
use utf8;

use Clib::Proc qw|script1 lib|;
use Clib::Const ':utf8';
use Clib::Log 'log_maxd';

use Clib::DT;

use Cache::Memcached::Fast;
use RedisDB;
use Encode;

use MaxAPI;
use flyinf;

$SIG{__DIE__} = sub { error('DIE: %s', $_) for @_ };

# можно уходить в фон
Clib::Proc::daemon(
    pidfile => (c('pidPath')||'.').'/maxd.pid',
    procname => 'Manifest-Max-Bot',
    no => c('maxd_nodaemon'),
) || exit -1;

my $isrun = 1;
Clib::Proc::sigint(sub { 
    log('Interrupted');
    if ($isrun) {
        undef $isrun;
    }
    if (MaxAPI->isreq()) {
        # Костыль для выхода из запроса.
        die 'Terminate';
    }
});

# Подключаемся к API и проверяем авторизацию
my $me;
while ($isrun) {
    $me = MaxAPI->me() || exit -1;
    
    last if $me->{is_bot} && $me->{user_id};

    # Запуститься процесс может, когда у нас нет соединения с интернет,
    # поэтому не выходим, а ждём, когда появятся данные
    # с интервалом 5-10 минут
    error('Not valid token or Max-API fail');
    sleep 300;
}

# скидываем все уже имеющиеся сообщения
my $mark = '';
if ($isrun) {
    my $upd = MaxAPI->updates(timeout => 1);
    if (!$upd || !$upd->{marker} || !$upd->{updates}) {
        error('Can\'t get-updates on init');
        exit -1;
    }
    $mark = $upd->{marker};
    foreach my $u (@{ $upd->{updates} || [] }) {
        if (my $msg = $u->{message}) {
            debug('Skip %s[%s] on %s from %s: %s',
                $u->{update_type},
                ($msg->{body}||{})->{mid}, Clib::DT::datetime(int($msg->{timestamp}/1000)),
                $msg->{sender}->{first_name} || '['.$msg->{sender}->{user_id}.']',
                ($msg->{body}||{})->{text}
            );
        }
        else {
            debug('Skip %s on %s from %s',
                $u->{update_type}, Clib::DT::datetime(int($u->{timestamp}/1000)),
                $u->{user} ? $u->{user}->{first_name} : '['.($u->{user_id}||'?').']'
            );
        }
    }
}

log('Starting with [%s] %s', $me->{username}, $me->{first_name});

# основной цикл
my %wait = ();
while ($isrun) {
    my $upd = MaxAPI->updates(timeout => 15, mark => $mark);
    if (!$upd || !$upd->{marker} || !$upd->{updates}) {
        error('get-updates fail');
        $isrun || last;
        sleep 60;
        next;
    }
    $mark = $upd->{marker};
    foreach my $u (@{ $upd->{updates} || [] }) {
        my $msg = $u->{message} || next;
        my $txt = ($msg->{body}||{})->{text} || next;
        my $user = $msg->{sender} || next;
        my $userid = $user->{user_id};
        log('%s[%s] on %s from %s: %s',
            $u->{update_type},
            ($msg->{body}||{})->{mid}, Clib::DT::datetime(int($msg->{timestamp}/1000)),
            $user->{first_name} || '['.int($userid).']',
            $txt
        );
        
        if ($txt =~ /^\/?(?:ком(анд)|help|start?)/i) {
            reply($userid, 'help');
        }
        elsif ($txt =~ /^\/?(?:я|im?)(\s+(.+))?$/i) {
            if (defined $1) {
                delete $wait{$userid};
                cmd_im($user, $1);
            }
            else {
                $wait{$userid} = 'im';
                reply($userid, 'im_waitname');
            }
        }
        elsif ($txt =~ /^\/?(?:уд(алить)?|unreg|del(ete)?)/i) {
            delete $wait{$userid};
            cmd_unreg($user);
        }
        elsif ($txt =~ /^\/?(?:инф(ормация)?|inf(o)?)/i) {
            delete $wait{$userid};
            cmd_inf($user);
        }
        elsif ($txt =~ /^\/?(?:ппу|ppu)/i) {
            delete $wait{$userid};
            cmd_ppu($user);
        }
        elsif (my $w = $wait{$userid}) {
            my $ok = -1;
            if ($w eq 'im') {
                $ok = cmd_im($user, $txt);
            }
            
            if ($ok) {
                delete $wait{$userid};
            }
        }
    }
}

log('Finished');

# Ответ в чат с пользователем
sub reply {
    my $userid = shift();
    
    my $msg = shift();
    if (my $s = c(telegram_reply => $msg)) {
        $msg = $s;
    }
    
    $msg = sprintf($msg, @_) if @_;
    
    my $r = MaxAPI->msgtxt($userid, $msg);
    
    if ($r) {
        debug('Send[userid=%d] %s', $userid, $msg);
    }
    else {
        error('Can\'t send to userid=%d', $userid);
    }
    
    return $r && $r->{message} ? 1 : 0;
}

# Соединение с Redis
my $redis;
sub redis {
    my $userid = shift;
    
    $redis ||= RedisDB->new(
                raise_error => 0,
                lazy => 1,
                
                %{ c('redis')||{} },
            );
    
    if (!$redis) {
        reply($userid, 'db') if $userid;
        return;
    }
    
    @_ || return 1;
    
    my $command = shift;
    my @uccom = split /_/, uc $command;
    
    my $ret = $redis->execute(@uccom, @_);
    
    if (ref($ret) =~ /RedisDB\:\:Error/) {
        error('[Redis ERROR] : %s', $ret->as_string);
        reply($userid, 'db') if $userid;
        return;
    }
    elsif (!$ret && $@) {
        error('[Redis EXCEPTION] : %s', $@);
        reply($userid, 'db') if $userid;
        return;
    }
    
    if (defined($ret) && !ref($ret)) {
        Encode::_utf8_on($ret);
    }
    
    return $ret;
}

##==========================================================
##==========================================================
##==========================================================

# Регистрация в системе
sub cmd_im {
    my ($user, $name) = @_;
    
    # проверка формата указанного имени
    my @name;
    if (!defined($name) ||
        !(@name = ($name =~ /^\s*(([a-zA-Zа-яА-ЯёЁ]+)(?:\s*([a-zA-Zа-яА-ЯёЁ]\.(?:[a-zA-Zа-яА-ЯёЁ]\.)?))?)\s*$/))) {
        reply($user->{user_id}, 'im_format');
        debug('name: %s', $name);
        return;
    }
    
    my ($full, $fam, $io) = @name;
    
    # Формируем регулярку, по которой будем искать это имя во взлёте
    my $regexp = $fam;
    if ($io) {
        $io =~ s/\./\\\./g;
        $io =~ s/[еёЕЁ]/[еёЕЁ]/g;
        $regexp .= '\s*' . $io;
    }
    
    # Если есть уже регистрация, мы её сначала удалим
    if (redis($user->{user_id}, hexists => mname  => $user->{user_id})) {
        cmd_unreg($user) || return;
    }
    
    # Регистрируемся в базе пользователей
    redis($user->{user_id}, hset => mname  => $user->{user_id} => $full) || return;
    redis($user->{user_id}, hset => mregexp=> $user->{user_id} => $regexp) || return;
    
    # Ответ пользователю об успехе
    reply($user->{user_id}, 'im_ok', $name[0]);
    
    1;
}

# Отмена регистрации в системе
sub cmd_unreg {
    my ($user) = @_;
    
    my $name = redis($user->{user_id}, hget => mname  => $user->{user_id});
    
    # Если нет регистрации в этом чате, то надо об этом сообщить
    if (!defined($name)) {
        reply($user->{user_id}, 'unreg_noexists');
        return;
    }
    
    # Удаляем из базы пользователей
    redis($user->{user_id}, hdel => mregexp=> $user->{user_id}) || return;
    redis($user->{user_id}, hdel => mname  => $user->{user_id}) || return;
    
    # Ответ пользователю об успехе
    reply($user->{user_id}, 'unreg_ok', $name);
    
    1;
}

# Получение информации о взлётах
sub cmd_inf {
    my ($user) = @_;
    
    my $name = redis($user->{user_id}, hget => mname  => $user->{user_id});
    
    # Если нет регистрации в этом чате, то надо об этом сообщить
    if (!defined($name)) {
        reply($user->{user_id}, 'inf_noexists');
        return;
    }
    
    # Нам нужна регулярка, по которой мы будем искать себя во взлётах
    my $regexp = redis($user->{user_id}, hget => mregexp  => $user->{user_id});
    if (!$regexp) {
        reply($user->{user_id}, 'db');
        return;
    }
    
    # Получаем список взлётов
    my $memd = Cache::Memcached::Fast->new( c('MemCached') );
    if (!$memd) {
        reply($user->{user_id}, 'db');
        return;
    }
    
    my $flyday = $memd->get('flyday');
    if ((ref($flyday) ne 'HASH') || (ref($flyday->{flylist}) ne 'ARRAY')) {
        reply($user->{user_id}, 'inf_flynull');
        return;
    }
    
    # Перебираем список взлётов
    my (@flytoff, @flywait, @flyover);
    # Поле state (взято из flyinf->fstate()):
    # H - скрытый взлёт (иногда так помечают давно улетевший)
    # q - в очереди
    # b - взлёт, которому дана готовность
    # f - недавно улетевший (ещё летающий)
    # h - давно улетевший (выполненный взлёт)
    foreach my $fly (@{ $flyday->{flylist} }) {
        # Смотрим, есть ли мы в этом взлёте
        my @pers =
            grep { $_->{name} =~ /^$regexp$/i }
            @{ $fly->{pers} || [] };
        @pers || next;
        
        # Определяем состояние этого взлёта
        flyinf->fstate($fly);
        flyinf->fsheet($fly);
        my $list =
            $fly->{state} eq 't' ?
                \@flytoff :
            ($fly->{state} eq 'q') || ($fly->{state} eq 'b') ?
                \@flywait :
                \@flyover;
        
        push @$list, map { { fly => $fly, pers => $_ } } @pers;
    }
    
    # Формируем ответ
    my @reply = ();
    
    # Только что улетевшие взлёты
    push @reply,
        map {
            my $fly = $_->{fly};
            sprintf(c(telegram_reply => 'inf_flytoff'),
                $fly->{name},
                $fly->{sheet}->{name},
                $fly->{closed_recently} / 60
            );
        }
        @flytoff;

    # Планируемые взлёты
    push(@reply, '') if @reply && @flywait;
    push @reply,
        map {
            my $fly = $_->{fly};
            $fly->{state} eq 'b' ?
                # взлёт в готовности
                sprintf(c(telegram_reply => 'inf_flybefore'),
                    $fly->{name},
                    $fly->{sheet}->{name},
                    $fly->{before} / 60
                ) :
                # взлёт в очереди
                sprintf(c(telegram_reply => 'inf_flyqueue'),
                    $fly->{name},
                    $fly->{sheet}->{name},
                    flyinf->pers_addinfo($_->{pers})
                );
        }
        @flywait;
    
    # Если нас нет в планируемых и только что улетевших взлётах,
    # на это своё сообщение
    if (!@reply) {
        push @reply, c(telegram_reply => 'inf_flynoqueue');
    }
    
    # Давно улетевшие взлёты - списком с заголовком
    if (@flyover) {
        push @reply,
            '',
            c(telegram_reply => 'inf_oldhead'),
            map {
                my $fly = $_->{fly};
                sprintf(c(telegram_reply => 'inf_flyitem'),
                    $fly->{name},
                    $fly->{sheet}->{name},
                    flyinf->pers_addinfo($_->{pers})
                );
            }
            @flyover;
    }
    
    # Общая сумма за все прыги
    my $summ = 0;
    foreach (@flywait, @flytoff, @flyover) {
        my $p = $_->{pers};
        # К долгу не привязываемся, т.к. Алина может вечером заранее выписать
        # всех должников и убрать слово "долг"
        next if $p->{code} !~ /^(\s*долг)?\s*(\d+)\s*$/i;
        $summ += $2;
    }
    push @reply,
        '',
        $summ > 0 ?
            sprintf(c(telegram_reply => 'inf_paysumm'), $summ) :
            c(telegram_reply => 'inf_nopay');
    
    # Отвечаем в чат
    return reply($user->{user_id}, join("\n", @reply));
}

# стенограмма ППУ
sub cmd_ppu {
    my ($user) = @_;
    
    my $file = c('ppufile') || return;
    
    my $fh;
    if (!(-e $file) || !open($fh, $file)) {
        return reply($user->{user_id}, c(telegram_reply => 'ppu_noexists'));
    }
    
    local $/ = undef;
    my $data = <$fh>;
    Encode::_utf8_on($data);
    close $fh;
    
    if (!$data) {
        return reply($user->{user_id}, c(telegram_reply => 'ppu_noexists'));
    }
    
    return reply($user->{user_id}, $data);
}

